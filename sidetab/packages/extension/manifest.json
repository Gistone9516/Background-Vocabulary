{
  "manifest_version": 3,
  "name": "배경지식 사이드탭",
  "version": "0.1.0",
  "description": "교차전공 빌더를 위한 핵심 어휘 추천 크롬 확장",
  "permissions": [
    "sidePanel",
    "storage"
  ],
  "host_permissions": [
    "https://sidetab-api.example.workers.dev/*"
  ],
  "background": {
    "service_worker": "sw.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "배경지식 사이드탭 열기",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
